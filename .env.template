# Foundry Local Model Catalog Sample — Environment Configuration
#
# This sample uses your kubeconfig for Kubernetes authentication,
# not environment variables. No .env file is needed to run the sample.
#
# If you need to point to a specific kubeconfig file, set:
# KUBECONFIG=/path/to/your/kubeconfig
#
# Optional: override the default Kubernetes namespace
# FOUNDRY_NAMESPACE=foundry-local-operator
